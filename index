<!DOCTYPE html>
<html lang="sr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Čovek ili AI? — Trening kviz</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,600;9..144,900&family=Spline+Sans+Mono:wght@400;500;700&display=swap');

  :root {
    --bg: #0e0f13;
    --surface: #16181f;
    --surface-2: #1d2029;
    --ink: #f4f1ea;
    --ink-dim: #9a9aa6;
    --line: #2a2d38;
    --human: #e8b04b;
    --human-bg: rgba(232,176,75,.12);
    --ai: #4ad1c9;
    --ai-bg: rgba(74,209,201,.12);
    --good: #5fcf80;
    --bad: #ec6a5e;
    --accent: #e8b04b;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    background: var(--bg);
    background-image:
      radial-gradient(circle at 12% 18%, rgba(232,176,75,.07), transparent 42%),
      radial-gradient(circle at 88% 82%, rgba(74,209,201,.07), transparent 42%);
    color: var(--ink);
    font-family: 'Spline Sans Mono', monospace;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 32px 20px 60px;
    -webkit-font-smoothing: antialiased;
  }

  .wrap { width: 100%; max-width: 720px; }

  header { text-align: center; margin-bottom: 36px; }

  .kicker {
    font-size: 11px;
    letter-spacing: .32em;
    text-transform: uppercase;
    color: var(--ink-dim);
    margin-bottom: 18px;
  }

  h1 {
    font-family: 'Fraunces', serif;
    font-weight: 900;
    font-size: clamp(34px, 8vw, 60px);
    line-height: .98;
    letter-spacing: -.02em;
  }
  h1 em {
    font-style: italic;
    color: var(--accent);
  }

  .sub {
    color: var(--ink-dim);
    font-size: 14px;
    line-height: 1.6;
    max-width: 460px;
    margin: 18px auto 0;
  }

  /* progress */
  .meta-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 12px;
    color: var(--ink-dim);
    margin-bottom: 10px;
    letter-spacing: .05em;
  }
  .track {
    height: 6px;
    background: var(--surface-2);
    border-radius: 999px;
    overflow: hidden;
    margin-bottom: 30px;
  }
  .bar {
    height: 100%;
    width: 0%;
    background: linear-gradient(90deg, var(--human), var(--ai));
    border-radius: 999px;
    transition: width .45s cubic-bezier(.2,.7,.2,1);
  }

  /* card */
  .card {
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 18px;
    padding: 30px 28px 28px;
    position: relative;
    box-shadow: 0 24px 60px -30px rgba(0,0,0,.8);
  }
  .card-label {
    font-size: 10px;
    letter-spacing: .3em;
    text-transform: uppercase;
    color: var(--ink-dim);
    margin-bottom: 16px;
  }
  .text-body {
    font-family: 'Fraunces', serif;
    font-size: 19px;
    line-height: 1.62;
    color: var(--ink);
    white-space: pre-line;
  }

  .choices {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px;
    margin-top: 28px;
  }
  .choice {
    appearance: none;
    border: 1.5px solid var(--line);
    background: var(--surface-2);
    color: var(--ink);
    font-family: 'Spline Sans Mono', monospace;
    font-size: 15px;
    font-weight: 700;
    letter-spacing: .03em;
    padding: 18px 14px;
    border-radius: 12px;
    cursor: pointer;
    transition: transform .15s ease, border-color .2s, background .2s;
  }
  .choice:hover { transform: translateY(-2px); }
  .choice[data-k="human"]:hover { border-color: var(--human); background: var(--human-bg); }
  .choice[data-k="ai"]:hover { border-color: var(--ai); background: var(--ai-bg); }
  .choice .small { display: block; font-size: 10px; font-weight: 400; color: var(--ink-dim); margin-top: 5px; letter-spacing: .12em; text-transform: uppercase; }

  /* reveal */
  .reveal { margin-top: 26px; display: none; animation: rise .4s ease both; }
  .reveal.show { display: block; }
  @keyframes rise { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }

  .verdict {
    display: flex;
    align-items: center;
    gap: 12px;
    font-weight: 700;
    font-size: 15px;
    padding: 14px 16px;
    border-radius: 12px;
    margin-bottom: 16px;
  }
  .verdict.correct { background: rgba(95,207,128,.12); border: 1px solid rgba(95,207,128,.35); color: var(--good); }
  .verdict.wrong { background: rgba(236,106,94,.12); border: 1px solid rgba(236,106,94,.35); color: var(--bad); }
  .verdict .icon { font-size: 20px; }

  .tag {
    display: inline-block;
    font-size: 11px;
    letter-spacing: .12em;
    text-transform: uppercase;
    padding: 4px 10px;
    border-radius: 999px;
    margin-bottom: 12px;
    font-weight: 700;
  }
  .tag.human { background: var(--human-bg); color: var(--human); }
  .tag.ai { background: var(--ai-bg); color: var(--ai); }

  .explain {
    font-size: 14px;
    line-height: 1.7;
    color: var(--ink-dim);
  }
  .explain strong { color: var(--ink); font-weight: 700; }

  .next {
    margin-top: 22px;
    width: 100%;
    border: none;
    background: var(--accent);
    color: #1a1500;
    font-family: 'Spline Sans Mono', monospace;
    font-weight: 700;
    font-size: 15px;
    letter-spacing: .04em;
    padding: 16px;
    border-radius: 12px;
    cursor: pointer;
    transition: filter .2s, transform .15s;
  }
  .next:hover { filter: brightness(1.08); transform: translateY(-2px); }

  /* result */
  .result { display: none; text-align: center; animation: rise .5s ease both; }
  .result.show { display: block; }
  .score-num {
    font-family: 'Fraunces', serif;
    font-weight: 900;
    font-size: clamp(60px, 18vw, 120px);
    line-height: 1;
    color: var(--accent);
    letter-spacing: -.03em;
  }
  .score-of { color: var(--ink-dim); font-size: 16px; margin-top: 4px; }
  .score-msg {
    font-family: 'Fraunces', serif;
    font-style: italic;
    font-size: 22px;
    margin: 22px auto 8px;
    max-width: 440px;
    line-height: 1.4;
  }
  .score-pct { color: var(--ink-dim); font-size: 14px; margin-bottom: 30px; }
  .restart {
    border: 1.5px solid var(--line);
    background: transparent;
    color: var(--ink);
    font-family: 'Spline Sans Mono', monospace;
    font-weight: 700;
    font-size: 14px;
    padding: 14px 30px;
    border-radius: 12px;
    cursor: pointer;
    transition: border-color .2s, background .2s;
  }
  .restart:hover { border-color: var(--accent); background: var(--human-bg); }

  .breakdown {
    margin-top: 36px;
    text-align: left;
    border-top: 1px solid var(--line);
    padding-top: 24px;
  }
  .breakdown h3 {
    font-family: 'Fraunces', serif;
    font-size: 18px;
    margin-bottom: 16px;
  }
  .b-item {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 13px;
    padding: 10px 0;
    border-bottom: 1px solid var(--line);
    color: var(--ink-dim);
  }
  .b-item .dot { width: 9px; height: 9px; border-radius: 50%; flex-shrink: 0; }
  .b-item .dot.ok { background: var(--good); }
  .b-item .dot.no { background: var(--bad); }
  .b-item .n { color: var(--ink); font-weight: 700; min-width: 22px; }

  footer {
    margin-top: 44px;
    text-align: center;
    font-size: 11px;
    color: var(--ink-dim);
    letter-spacing: .08em;
  }
  footer a { color: var(--accent); text-decoration: none; }
</style>
</head>
<body>
<div class="wrap">
  <header>
    <div class="kicker">Trening — prepoznavanje AI sadržaja</div>
    <h1>Čovek <em>ili</em> AI?</h1>
    <p class="sub">Osam tekstova. Dva moguća odgovora. Proveri da li možeš da prepoznaš šta je pisao čovek, a šta veštačka inteligencija — i saznaj zašto, posle svakog odgovora.</p>
  </header>

  <div id="quiz">
    <div class="meta-row">
      <span id="qcount">Pitanje 1 / 8</span>
      <span id="qscore">0 tačnih</span>
    </div>
    <div class="track"><div class="bar" id="bar"></div></div>

    <div class="card">
      <div class="card-label">Tekst za procenu</div>
      <div class="text-body" id="textBody"></div>

      <div class="choices" id="choices">
        <button class="choice" data-k="human">Pisao čovek<span class="small">ljudski autor</span></button>
        <button class="choice" data-k="ai">Pisao AI<span class="small">veštačka inteligencija</span></button>
      </div>

      <div class="reveal" id="reveal">
        <div class="verdict" id="verdict"></div>
        <span class="tag" id="tag"></span>
        <p class="explain" id="explain"></p>
        <button class="next" id="nextBtn">Sledeći tekst →</button>
      </div>
    </div>
  </div>

  <div class="result" id="result">
    <div class="kicker">Rezultat</div>
    <div class="score-num" id="finalNum">0</div>
    <div class="score-of">od 8 tačnih</div>
    <p class="score-msg" id="finalMsg"></p>
    <p class="score-pct" id="finalPct"></p>
    <button class="restart" id="restartBtn">Uradi ponovo</button>

    <div class="breakdown">
      <h3>Pregled po pitanjima</h3>
      <div id="breakdownList"></div>
    </div>
  </div>

  <footer>© 2026 Lazar Jovanović · Trening alat za prepoznavanje AI sadržaja</footer>
</div>

<script>
const QUESTIONS = [
  {
    text: `Probudila sam se u pet, pre alarma, sa onim čudnim osećajem da sam nešto zaboravila. Skuvala kafu, ostavila je da se ohladi — kao i obično. Tek kad sam sela na terasu shvatila sam da je danas tačno godinu dana otkako se baba odselila kod nas. Mačka je već bila na njenom stolici.`,
    answer: "human",
    why: `<strong>Čovek.</strong> Sitni, nelogični i nesvodivi detalji — kafa koja se ohladila „kao i obično", mačka na babinoj stolici — nose specifičnost koju modeli retko proizvode bez naloga. AI češće generalizuje emociju; čovek je „pokaže" kroz konkretan, naizgled nevažan detalj.`
  },
  {
    text: `Veštačka inteligencija predstavlja transformativnu tehnologiju koja menja način na koji poslujemo. U današnjem dinamičnom svetu, kompanije koje prihvate AI rešenja stiču značajnu konkurentsku prednost. Važno je napomenuti da implementacija zahteva pažljivo planiranje i posvećenost svih zainteresovanih strana.`,
    answer: "ai",
    why: `<strong>AI.</strong> Klasičan obrazac: opšte fraze bez ijednog konkretnog primera („transformativna tehnologija", „dinamičan svet", „zainteresovane strane"), uravnotežena struktura i obavezno „važno je napomenuti". Tekst zvuči glatko, ali ne kaže ništa proverljivo.`
  },
  {
    text: `Da budem iskren — prva tri meseca su bila katastrofa. Klijent je tražio „nešto moderno", a kad smo isporučili, ispalo je da je „moderno" za njega značilo logo iz 2009. Naučio sam da pitam šta tačno znači svaka reč u brifu. Skupa lekcija, ali vredna.`,
    answer: "human",
    why: `<strong>Čovek.</strong> Priznanje neuspeha, ironija („logo iz 2009"), prelom ritma kroz crticu i kolokvijalni ton. AI izbegava da ispadne loše i retko se ovako samouvereno ruga sopstvenom iskustvu bez eksplicitnog naloga.`
  },
  {
    text: `Postoji nekoliko ključnih prednosti korišćenja ovog pristupa. Prvo, povećava se efikasnost. Drugo, smanjuju se troškovi. Treće, poboljšava se korisničko iskustvo. U zaključku, ovaj metod nudi sveobuhvatno rešenje za moderne izazove sa kojima se organizacije suočavaju.`,
    answer: "ai",
    why: `<strong>AI.</strong> Numerisane prednosti bez konteksta, simetrične rečenice jednake dužine i „u zaključku" kao šablonski završetak. Nedostaju brojevi, izvori i bilo kakva tenzija — sve je „poboljšano" i „sveobuhvatno", što je tipičan AI manir.`
  },
  {
    text: `Pišem ovo u vozu za Niš, baterija na 11%, pa ću biti kratak. Sastanak je prošao bolje nego što sam očekivao. Onaj njihov finansijski direktor — sećaš se, onaj što stalno prekida — danas je ćutao ceo sat. Mislim da imamo deal. Javim detalje kad stignem.`,
    answer: "human",
    why: `<strong>Čovek.</strong> Situacioni kontekst (voz, baterija), unutrašnja referenca koju samo primalac razume („onaj što stalno prekida") i nedovršenost. Ovo je živa komunikacija, ne dorađen tekst — AI nema razlog da spominje 11% baterije.`
  },
  {
    text: `Održivi razvoj je danas više od trenda — to je neophodnost. Kompanije širom sveta prepoznaju važnost ekološki odgovornog poslovanja. Kroz inovativna rešenja i posvećenost zelenoj tranziciji, gradimo bolju budućnost za sve nas. Zajedno možemo napraviti razliku.`,
    answer: "ai",
    why: `<strong>AI.</strong> Niz nepovezanih opštih mesta i motivacioni završetak („zajedno možemo napraviti razliku"). Nema konkretne kompanije, brojke ni primera mere — samo prijatne fraze koje pristaju uz bilo koju temu. Visok „fluency", nulta specifičnost.`
  },
  {
    text: `Recept za bakine sarme: kiseli kupus, mleveno meso pola-pola, pirinač, i — ovo je tajna — kašika masti, ne ulja. Baba bi rekla da onaj ko štedi na masti nek se i ne lati sarmi. Kuva se tri sata na tihoj vatri. Ne diraj poklopac prvih sat vremena. Ozbiljno.`,
    answer: "human",
    why: `<strong>Čovek.</strong> Idiosinkratičan glas („nek se i ne lati sarmi"), lična zapovest („Ozbiljno.") i kulturno specifičan detalj koji nije iz standardnog recepta. AI bi dao uredan, neutralan recept; ovde se čuje konkretna osoba.`
  },
  {
    text: `Digitalna transformacija predstavlja proces integracije digitalnih tehnologija u sve aspekte poslovanja. Ovaj proces fundamentalno menja način na koji organizacije funkcionišu i isporučuju vrednost svojim klijentima. Ključ uspeha leži u strateškom pristupu i kontinuiranom prilagođavanju.`,
    answer: "ai",
    why: `<strong>AI.</strong> Definicija nalik na udžbenik, apstraktni glagoli („integriše", „isporučuje vrednost", „prilagođava") i odsustvo bilo kog stvarnog aktera ili rezultata. Tačno, gramatički besprekorno — i potpuno bezlično. To je potpis generisanog teksta.`
  }
];

let idx = 0, score = 0, answered = false;
const results = [];

const el = id => document.getElementById(id);

function render() {
  const q = QUESTIONS[idx];
  el('textBody').textContent = q.text;
  el('qcount').textContent = `Pitanje ${idx + 1} / ${QUESTIONS.length}`;
  el('qscore').textContent = `${score} tačnih`;
  el('bar').style.width = `${(idx / QUESTIONS.length) * 100}%`;
  el('reveal').classList.remove('show');
  el('choices').style.display = 'grid';
  answered = false;
  document.querySelectorAll('.choice').forEach(c => c.disabled = false);
}

document.querySelectorAll('.choice').forEach(btn => {
  btn.addEventListener('click', () => {
    if (answered) return;
    answered = true;
    const choice = btn.dataset.k;
    const q = QUESTIONS[idx];
    const correct = choice === q.answer;
    if (correct) score++;
    results.push({ i: idx + 1, correct, answer: q.answer });

    document.querySelectorAll('.choice').forEach(c => c.disabled = true);
    el('choices').style.display = 'none';

    const v = el('verdict');
    v.className = 'verdict ' + (correct ? 'correct' : 'wrong');
    v.innerHTML = correct
      ? `<span class="icon">✓</span> Tačno!`
      : `<span class="icon">✕</span> Netačno — pogrešna procena.`;

    const tag = el('tag');
    tag.className = 'tag ' + q.answer;
    tag.textContent = q.answer === 'human' ? 'Ovo je pisao čovek' : 'Ovo je pisao AI';

    el('explain').innerHTML = q.why;
    el('qscore').textContent = `${score} tačnih`;
    el('reveal').classList.add('show');
  });
});

el('nextBtn').addEventListener('click', () => {
  idx++;
  if (idx >= QUESTIONS.length) showResult();
  else render();
});

function showResult() {
  el('quiz').style.display = 'none';
  el('bar').style.width = '100%';
  const r = el('result');
  r.classList.add('show');
  el('finalNum').textContent = score;
  const pct = Math.round((score / QUESTIONS.length) * 100);
  el('finalPct').textContent = `${pct}% tačnih odgovora`;

  let msg;
  if (score === 8) msg = "Besprekorno. Tvoj detektor je kalibrisan — vidiš obrasce koje većina propušta.";
  else if (score >= 6) msg = "Vrlo dobro. Prepoznaješ glavne signale; promaši samo na rubnim, dobro doteranim tekstovima.";
  else if (score >= 4) msg = "Solidno, ali AI te je nekoliko puta zavarao. Obrati pažnju na specifičnost detalja, ne na glatkoću.";
  else msg = "Lako te je zavesti glatkim tekstom. Vežbaj da tražiš konkretne, proverljive detalje — to je ključni signal.";
  el('finalMsg').textContent = msg;

  const list = el('breakdownList');
  list.innerHTML = '';
  results.forEach(res => {
    const row = document.createElement('div');
    row.className = 'b-item';
    row.innerHTML = `
      <span class="dot ${res.correct ? 'ok' : 'no'}"></span>
      <span class="n">${res.i}.</span>
      <span>${res.correct ? 'Tačno' : 'Netačno'} — odgovor je bio: ${res.answer === 'human' ? 'čovek' : 'AI'}</span>`;
    list.appendChild(row);
  });
}

el('restartBtn').addEventListener('click', () => {
  idx = 0; score = 0; answered = false; results.length = 0;
  el('result').classList.remove('show');
  el('quiz').style.display = 'block';
  render();
});

render();
</script>
</body>
</html>
